# =============================================================================
# Budget — Environment Variables
# NEVER COMMIT the real .env file — it is git-ignored.
# Copy this file to .env and fill in real values before running.
# =============================================================================
# Generation helpers:
#   BUDGET_KEK:         openssl rand -base64 32
#   BETTER_AUTH_SECRET: openssl rand -base64 32
#   Passwords:          openssl rand -hex 16
# =============================================================================

# ── Postgres superuser (docker-compose db service) ───────────────────────────
POSTGRES_PASSWORD=changeme-dev-only

# ── Role-separated Postgres passwords (PC-19 / T-14) ─────────────────────────
# These are forwarded to infra/postgres/init/00-roles.sh at first-boot init.
# All roles are created NOBYPASSRLS (T-3 mitigation).
APP_ROLE_PASSWORD=changeme-dev-only
WORKER_ROLE_PASSWORD=changeme-dev-only
MIGRATOR_ROLE_PASSWORD=changeme-dev-only

# ── Role-separated connection DSNs (D-18) ─────────────────────────────────────
# Used by api, worker, and migrator services respectively.
DATABASE_URL_APP=postgresql://app_role:changeme-dev-only@db:5432/budget
DATABASE_URL_WORKER=postgresql://worker_role:changeme-dev-only@db:5432/budget
DATABASE_URL_MIGRATOR=postgresql://migrator:changeme-dev-only@db:5432/budget

# ── Crypto-shredding KEK (D-16) — 32-byte base64 ─────────────────────────────
# Generate: openssl rand -base64 32
BUDGET_KEK=

# ── Better Auth (D-15) ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-at-least-32-chars-longggg
BETTER_AUTH_URL=http://localhost:3001

# ── Application URLs ──────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Email (dev: mailpit capture) ─────────────────────────────────────────────
EMAIL_SMTP_HOST=mailpit
EMAIL_SMTP_PORT=1025

# ── Single region v1 (PLAT-11) ───────────────────────────────────────────────
REGION=eu-central-1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
