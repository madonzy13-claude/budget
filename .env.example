# Budget — Non-secret configuration template
# Copy to .env — this file is safe to commit.
#
# SECRETS (passwords, KEK, auth secret, DSNs) are stored in Infisical.
# Run `infisical secrets --env=dev` to view them.
# Run `make dev` — Infisical injects secrets automatically before compose starts.
#
# To add a new secret:  make secrets-set KEY=MY_SECRET VALUE=the-value
# To rotate a secret:   infisical secrets set MY_SECRET=new-value --env=dev

# ── Application URLs ──────────────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3001
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Email (dev: mailpit SMTP capture) ────────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=no-reply@budget.local
# SMTP_USER=
# SMTP_PASS=

# ── Region (PLAT-11) ─────────────────────────────────────────────────────────
REGION=eu-central-1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
