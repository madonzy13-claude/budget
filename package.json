{
  "name": "budget",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "bun run --filter='*' typecheck",
    "lint": "eslint .",
    "depcheck": "depcruise --config .dependency-cruiser.cjs apps packages",
    "grep:no-direct-tx": "! grep -RnE '\\.transaction\\(' --include='*.ts' --exclude=tx.ts --exclude-dir=test --exclude-dir=node_modules apps packages",
    "grep:no-pool-connect": "! grep -RnE 'appPool\\(\\)\\.connect\\(' --include='*.ts' --exclude=tx.ts --exclude-dir=test --exclude-dir=node_modules packages apps",
    "test:ci-gate": "bash scripts/ci/run-tenant-leak.sh"
  },
  "devDependencies": {
    "@budget/db": "workspace:*",
    "@budget/identity": "workspace:*",
    "@budget/platform": "workspace:*",
    "@budget/shared-kernel": "workspace:*",
    "@budget/tenancy": "workspace:*",
    "@playwright/test": "latest",
    "@types/bun": "^1.3.0",
    "@types/pg": "^8.11.0",
    "drizzle-orm": "^0.45.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.7",
    "pg": "^8.13.0",
    "playwright-bdd": "^8.5.0",
    "prettier": "^3.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
