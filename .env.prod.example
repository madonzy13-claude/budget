# ==============================================================================
# Budget — production environment template
# ------------------------------------------------------------------------------
# Copy to `.env.prod` next to docker-compose.prod.yml and fill in real values:
#     cp .env.prod.example .env.prod && chmod 600 .env.prod
#
# `.env.prod` holds secrets and is git-ignored — keep it that way. Run compose
# with `--env-file .env.prod` (the tracked `.env` is the non-secret dev file).
#
# Generate strong secrets:
#     openssl rand -base64 24        # each DB password
#     openssl rand -base64 48        # BETTER_AUTH_SECRET (needs >= 32 chars)
#     openssl rand -base64 32        # BUDGET_KEK (32 raw bytes, base64)
# ==============================================================================

# ── Release to run ────────────────────────────────────────────────────────────
# Pin a published release (recommended) or leave commented to track :latest.
# BUDGET_VERSION=v1.0.0

# ── Postgres roles (pick strong, distinct passwords) ──────────────────────────
POSTGRES_PASSWORD=change-me-superuser
APP_ROLE_PASSWORD=change-me-app
WORKER_ROLE_PASSWORD=change-me-worker
MIGRATOR_ROLE_PASSWORD=change-me-migrator

# ── Database URLs (must embed the passwords above; host is the `db` service) ───
# Keep the role<->password pairing in sync with the four values above. Note the
# role names: app_role / worker_role / migrator (the migrator role is NOT suffixed
# "_role", even though its password env var is MIGRATOR_ROLE_PASSWORD).
DATABASE_URL_APP=postgresql://app_role:change-me-app@db:5432/budget
DATABASE_URL_WORKER=postgresql://worker_role:change-me-worker@db:5432/budget
DATABASE_URL_MIGRATOR=postgresql://migrator:change-me-migrator@db:5432/budget

# ── Auth + app URLs ───────────────────────────────────────────────────────────
# BETTER_AUTH_SECRET must be >= 32 chars. APP_URL / BETTER_AUTH_URL are the
# PUBLIC https origin your reverse proxy serves. TRUSTED_ORIGINS is a CSV of
# every origin the browser will call from (usually just APP_URL).
BETTER_AUTH_SECRET=change-me-at-least-32-characters-long
BETTER_AUTH_URL=https://budget.example.com
APP_URL=https://budget.example.com
TRUSTED_ORIGINS=https://budget.example.com

# ── Encryption key (envelope KEK for per-user data encryption) ────────────────
# 32 raw bytes, base64-encoded. NEVER rotate without a re-encryption plan —
# losing it makes encrypted PII unrecoverable.
BUDGET_KEK=change-me-base64-32-bytes

# ── Email (transactional: verification, password reset, invites) ──────────────
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_FROM=no-reply@budget.example.com
SMTP_USER=
SMTP_PASS=

# ── Web Push (optional) ───────────────────────────────────────────────────────
# The PUBLIC key must match the one baked into the web image at build time
# (repo variable NEXT_PUBLIC_VAPID_PUBLIC_KEY). Generate a pair with
# `npx web-push generate-vapid-keys`. Leave blank to run without push.
VAPID_SUBJECT=mailto:admin@budget.example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Investment price providers (optional; auto-fetch degrades if unset) ───────
# Each *_API_KEYS accepts a comma-separated list for round-robin failover.
FINNHUB_API_KEYS=
TWELVE_DATA_API_KEYS=
COINGECKO_API_KEYS=
METALS_DEV_API_KEY=

# ── Misc ──────────────────────────────────────────────────────────────────────
REGION=eu-central-1
LOG_LEVEL=info
# Worker price-scan cron (UTC). Default: top of every hour.
PRICE_SCAN_CRON=0 * * * *
