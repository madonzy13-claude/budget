# Budget — Non-secret configuration
# Secrets live in Infisical: `infisical secrets --env=dev`
# Use `make dev` to start the stack (secrets injected automatically)

# ── Application URLs ──────────────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3001
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Email (dev: mailpit SMTP capture) ────────────────────────────────────────
EMAIL_SMTP_HOST=mailpit
EMAIL_SMTP_PORT=1025

# ── Region (PLAT-11) ─────────────────────────────────────────────────────────
REGION=eu-central-1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
