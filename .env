# Budget — Non-secret configuration
# Secrets live in Infisical: `infisical secrets --env=dev`
# Use `make dev` to start the stack (secrets injected automatically)

# ── Application URLs ──────────────────────────────────────────────────────────
# BETTER_AUTH_URL must equal the user-visible web URL — Better Auth uses it
# to construct verification/reset links. Do NOT point it at the api port; the
# api container is internal-only (web proxies /auth/* and /api/auth/* to api:4000).
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000,http://claude-code.tail4b2401.ts.net:3000
NEXT_PUBLIC_API_URL=
API_INTERNAL_URL=http://api:4000

# ── Email (dev: mailpit SMTP capture) ────────────────────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=no-reply@budget.local

# ── Region (PLAT-11) ─────────────────────────────────────────────────────────
REGION=eu-central-1

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Investments price refresh (Phase 9) ──────────────────────────────────────
# Cron for the held-instrument price scan (UTC). Lower frequency ⇒ more distinct
# instruments fit under each provider's free-tier daily credit cap. Default 3h.
PRICE_SCAN_CRON=0 */3 * * *
# Provider API keys are SECRETS — set in Infisical, not here. Each accepts a
# comma-separated list (round-robin failover when one key hits its rate limit):
#   FINNHUB_API_KEYS       (US stocks/ETF)
#   TWELVE_DATA_API_KEYS   (non-US equities/ETF + XAU/USD, XAG/USD metals)
#   COINGECKO_API_KEYS     (crypto; demo keys)
# Singular *_API_KEY is still honored as a single-key fallback.
